---
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { Home, FolderCode, BookOpenText, FileUser } from 'lucide-astro';
import { Image } from 'astro:assets';
import miFoto from '../assets/JohanaMDev.jpg';
import Footer from '../components/Footer.astro'; 

const { title = SITE_TITLE, description = SITE_DESCRIPTION } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="dracula">
    <head>
        <BaseHead title={title} description={description} />
        <GoogleAnalytics />

        <meta name="google-site-verification" content="F-hgbToUjLWvjMvkxqcmEntVTPnHd3VcjOOYEkyF1UM" />
    
        <ClientRouter />
    </head>
    <body>
        <div class="drawer lg:drawer-open">
        <input id="my-drawer" type="checkbox" class="drawer-toggle" />
        
        <div class="drawer-content flex flex-col bg-base-100 min-h-screen">
            <div class="sticky top-0 z-30 flex h-16 w-full justify-center bg-opacity-90 backdrop-blur transition-all duration-100 bg-base-100 text-base-content shadow-sm lg:hidden">
                <div class="navbar">
                    <div class="navbar-start">
                        <label for="my-drawer" class="btn btn-square btn-ghost">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                        </label>
                    </div>
                    <div class="navbar-center">
                        <a class="btn btn-ghost normal-case text-xl lg:hidden">Johana Veas</a>
                    </div>
                    <div class="navbar-end"></div>
                </div>
            </div>
            
            <main class="p-6 md:p-10 flex-grow w-full max-w-[100vw] md:max-w-5xl mx-auto">
                <slot /> 
            </main>

                <Footer />
            </div> 

            <div class="drawer-side z-40">
                <label for="my-drawer" class="drawer-overlay"></label> 
                <aside class="bg-base-200 w-80 min-h-full flex flex-col p-6 border-r border-white/5">
                    
                    <div class="avatar flex justify-center mb-6">
                        <div class="w-32 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2 shadow-xl">
                            <Image src={miFoto} alt="Johana" width={128} height={128} format="webp" />
                        </div>
                    </div>
                    
                    <div class="text-center mb-8">
                        <h1 class="text-2xl font-bold tracking-tight text-white">Johana Veas</h1>
                        <p class="text-sm opacity-70 font-medium text-primary uppercase tracking-widest mt-1">Java Developer</p>
                    </div>

                    <ul class="menu menu-md p-0 text-base-content grow gap-2">
                        <li>
                            <a href="/" class="flex items-center gap-4 py-3 px-4 rounded-xl transition-all duration-300 hover:bg-primary/10 hover:text-primary active:scale-95">
                                <Home size={22} class="text-primary" /> <span class="font-semibold">Home</span>
                            </a>
                        </li>
                        <li>
                            <a href="/projects" class="flex items-center gap-4 py-3 px-4 rounded-xl transition-all duration-300 hover:bg-primary/10 hover:text-primary active:scale-95">
                                <FolderCode size={22} class="text-primary" /> <span class="font-semibold">Projects</span>
                            </a>
                        </li>
                        <li>
                            <a href="/blog" class="flex items-center gap-4 py-3 px-4 rounded-xl transition-all duration-300 hover:bg-primary/10 hover:text-primary active:scale-95">
                                <BookOpenText size={22} class="text-primary" /> <span class="font-semibold">Behind the Code</span>
                            </a>
                        </li>
                        <li>
                            <a href="/cv" class="flex items-center gap-4 py-3 px-4 rounded-xl transition-all duration-300 hover:bg-primary/10 hover:text-primary active:scale-95">
                                <FileUser size={22} class="text-primary" /> <span class="font-semibold">CV</span>
                            </a>
                        </li>
                    </ul>

                    <div class="divider opacity-20"></div>
                    
                    <div class="text-center text-[10px] opacity-30 font-mono italic">
                        "Get things done"
                    </div>
                </aside>
            </div>
        </div>
    </body>
</html>