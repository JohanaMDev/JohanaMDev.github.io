---
import type { CollectionEntry } from 'astro:content';
import MainLayout from './MainLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { CalendarDays, Clock3 } from 'lucide-astro';
import { Image } from 'astro:assets';

type Props = CollectionEntry<'projects_info'>['data'];

const { title, description, pubDate, heroImage } = Astro.props;
---

<MainLayout title={title} description={description}>
  <article class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    
    <header class="mb-16 text-center md:text-left border-b border-base-content/10 pb-12">
      <div class="flex items-center justify-center md:justify-start gap-6 text-sm font-medium text-base-content/60 mb-6 font-mono">
        <div class="flex items-center gap-2.5">
          <CalendarDays size={18} class="text-primary" />
          <FormattedDate date={pubDate} />
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tighter text-base-content mb-6 leading-tight">
        {title}
      </h1>

      <p class="text-xl md:text-2xl text-base-content/80 font-medium leading-relaxed max-w-3xl mx-auto md:mx-0">
        {description}
      </p>
    </header>

    <div class="prose prose-lg md:prose-xl max-w-none 
      prose-headings:text-base-content prose-headings:font-extrabold prose-headings:tracking-tight 
      prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-8 prose-h2:border-b-2 prose-h2:border-primary prose-h2:pb-3 prose-h2:inline-block
      prose-h3:text-2xl prose-h3:mt-12 prose-h3:mb-6 prose-h3:text-secondary
      prose-p:text-base-content/90 prose-p:leading-relaxed prose-p:mb-8
      prose-strong:text-base-content prose-strong:font-semibold
      prose-ul:list-disc prose-ul:pl-8 prose-ul:mb-10
      prose-li:mb-3
      prose-code:text-secondary prose-code:bg-base-300 prose-code:px-2 prose-code:py-0.5 prose-code:rounded-md prose-code:font-mono prose-code:text-sm
      prose-pre:bg-neutral prose-pre:shadow-xl prose-pre:rounded-2xl prose-pre:p-8 prose-pre:border prose-pre:border-white/5
      prose-img:max-w-2xl prose-img:mx-auto prose-img:rounded-2xl prose-img:shadow-xl
      prose-hr:border-base-content/10 prose-hr:my-16
      ">
      <slot />
    </div>
  </article>
</MainLayout>

<style is:global>
  html {
    font-feature-settings: "cv02", "cv03", "cv04", "cv11";
  }
</style>