---
const today = new Date();
---

<footer class="footer-container">
    <div class="footer-content font-mono">
        <span class="copyright-text">&copy; {today.getFullYear()} // JOHANA M. VEAS //</span>
        <span class="tech-stack text-accent font-bold">BUILT WITH ASTRO & JAVA ENERGY ☕</span>
    </div>
</footer>

<style>
    .footer-container {
        padding: 3em 1em; /* Ajustamos padding para que respire */
        text-align: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05); /* Línea divisoria sutil */
        margin-top: 2em;
        background-color: rgba(0, 0, 0, 0.1); /* Ligero fondo para separarlo */
    }
    .footer-content {
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }
    .copyright-text {
        color: rgba(255, 255, 255, 0.7); 
    }
    .text-accent {
        color: #8be9fd;
    }
</style>