---
const { title, img, desc, url, github, badge, tags = [] } = Astro.props;
import { Image } from "astro:assets";
import { Github as GithubIcon } from "lucide-astro";
---

<div class="group relative bg-base-100 border border-base-content/10 rounded-[2rem] overflow-hidden hover:border-primary/40 transition-all duration-500 shadow-xl mb-10">
  <div class="flex flex-col md:flex-row gap-6 p-6 md:p-10"> 
    <a href={url} class="w-full md:w-5/12 overflow-hidden rounded-2xl aspect-video shrink-0">
      <Image
        src={img}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-90 group-hover:opacity-100"
      />
    </a>

    <div class="flex-1 flex flex-col">
      <div class="flex items-center gap-3 mb-4">
        {badge && <span class="px-3 py-1 bg-primary/10 text-primary text-[10px] font-extrabold rounded-full uppercase tracking-tighter">{badge}</span>}
      </div>

      <h3 class="text-2xl md:text-3xl font-bold text-white mb-4 leading-tight">
        {title}
      </h3>
      
      <p class="text-base-content/70 text-sm md:text-base leading-relaxed mb-8 line-clamp-4 md:line-clamp-3">
        {desc}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-auto">
        <a href={url} class="btn btn-primary btn-md sm:btn-sm px-6 h-12 sm:h-10 normal-case grow sm:grow-0 shadow-lg shadow-primary/20">
            Ver Documentación
        </a>
        <a href={github} target="_blank" class="btn btn-outline btn-md sm:btn-sm px-6 h-12 sm:h-10 border-white/20 hover:bg-white/5 normal-case grow sm:grow-0 flex items-center justify-center gap-2 group">
            <span class="leading-none">Explorar Repo</span>
            <GithubIcon size={18} class="opacity-80 group-hover:rotate-12 transition-transform shadow-none" />
        </a>
      </div>
    </div>
  </div> <div class="px-6 md:px-10 py-5 bg-white/[0.03] border-t border-white/5 flex flex-wrap gap-x-4 md:gap-x-8 gap-y-3">
    {tags && tags.map((tag: string) => (
      <span class="text-[10px] font-mono text-white/70 uppercase tracking-[0.2em] font-medium">
        <span class="text-primary/50 mr-1">#</span>{tag}
      </span>
    ))}
  </div>
</div>