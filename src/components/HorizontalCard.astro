---
import { Image } from 'astro:assets';

const { title, img, desc, url, badge, target = "_blank" } = Astro.props;
const isAsset = typeof img === 'object';
---

<div class="rounded-2xl bg-white/[0.02] border border-white/10 hover:border-primary/40 transition-all duration-300 shadow-xl overflow-hidden group">
  <a href={url} target={target} class="flex flex-col md:flex-row">
    
    <div class="relative w-full md:w-1/3 overflow-hidden bg-base-300">
      {isAsset ? (
        <Image 
          src={img} 
          alt={title} 
          width={750} 
          height={422} 
          format="webp"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      ) : (
        <img
          src={img}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-base-300/80 to-transparent md:hidden"></div>
    </div>

    <div class="p-6 md:p-8 flex-1 flex flex-col justify-center">
      <div class="flex flex-wrap items-center gap-3 mb-2">
        <h3 class="text-2xl font-bold text-slate-100 group-hover:text-primary transition-colors">
          {title}
        </h3>
        {badge && (
          <div class="badge badge-outline border-primary/50 text-primary text-[10px] font-bold uppercase italic">
            {badge}
          </div>
        )}
      </div>
      <p class="text-slate-400 leading-relaxed text-sm md:text-base">
        {desc}
      </p>
      
      <div class="mt-6 flex items-center text-primary font-bold text-xs uppercase tracking-widest gap-2">
        Explorar Repositorio 
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </div>
    </div>
  </a>
</div>