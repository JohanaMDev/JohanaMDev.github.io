---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro'; // Usamos el mismo layout para mantener la estética

export async function getStaticPaths() {
    const projects = await getCollection('projects_info');
    return projects.map((project) => ({
        params: { slug: project.id },
        props: project,
    }));
}
type Props = CollectionEntry<'projects_info'>;

const project = Astro.props;
const { Content } = await render(project);
---

<BlogPost {...project.data}>
    <Content />
</BlogPost>