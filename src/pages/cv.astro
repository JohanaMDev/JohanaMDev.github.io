---
import MainLayout from "../layouts/MainLayout.astro";
import { FileDown, Briefcase, GraduationCap, Code2, Award, ExternalLink } from 'lucide-astro';
import certJava from "../assets/certificado-java.jpg";
import certPython from "../assets/Certificado Python_2023.png";
import certWeb from "../assets/programacion-web.jpg";
---

<MainLayout title="Currículum | Johana Veas">
  <div class="mb-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
    <div>
      <h1 class="text-4xl font-extrabold text-white tracking-tight mb-2">
        Curriculum <span class="text-primary italic">Vitae</span>
      </h1>
      <p class="text-slate-400 text-lg italic">"Get things done" — Perfil Técnico & Liderazgo.</p>
    </div>
    
    <a 
      href="/Cv Java Developer Johana Veas.pdf" 
      download 
      class="btn btn-primary btn-outline border-2 gap-2 hover:scale-105 transition-all shadow-lg shadow-primary/20"
    >
      <FileDown size={20} />
      Descargar PDF
    </a>
  </div>

  <div class="mb-12 p-6 bg-white/[0.02] border border-white/10 rounded-2xl relative overflow-hidden group">
    <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
        <Code2 size={120} />
    </div>
    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
      <Code2 class="text-primary" size={24} /> Perfil Profesional
    </h2>
    <p class="text-slate-300 leading-relaxed text-justify max-w-4xl">
      Líder de proyecto nata con perfil técnico y mentalidad <b>"Get things done"</b>. 
      Especializada en el desarrollo de software con Java, con un enfoque en entender el "porqué" del negocio para ejecutar el "cómo" técnico de manera eficiente. 
      Capacidad probada para diseñar arquitecturas robustas y gestionar flujos de trabajo bajo presión, manteniendo siempre una visión macro y una comunicación directa y concisa.
    </p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
    <div class="lg:col-span-2 space-y-12">
      
      <section>
        <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
          <Briefcase class="text-primary" size={28} /> Experiencia Destacada
        </h2>
        <div class="space-y-8 border-l-2 border-primary/20 ml-3 pl-8 relative">
          <div class="relative">
            <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-primary border-4 border-base-100 shadow-[0_0_10px_rgba(255,121,198,0.5)]"></div>
            <h3 class="text-lg font-bold text-white">Desarrolladora Java & Lead de Proyecto Independiente</h3>
            <p class="text-sm text-primary font-mono mb-3 uppercase tracking-wider italic">Enero 2026 — Actualidad</p>
            <p class="text-slate-400 text-sm leading-relaxed">
              Diseño y ejecución de un <b>Sistema de Gestión de Inventario</b> integral. 
              Implementación de jerarquías de servicios para validación de datos (Venta -> Empleado -> Puesto), 
              manejo de autenticación, lógica de proveedores y gestión fiscal de usuarios. 
              Uso intensivo de Spring Boot, PostgreSQL y despliegue continuo.
            </p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
          <GraduationCap class="text-primary" size={28} /> Formación Continua
        </h2>
        <div class="space-y-10 border-l-2 border-white/10 ml-3 pl-8 relative">
          
          <div class="relative">
            <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-slate-700 border-4 border-base-100"></div>
            <h3 class="text-lg font-bold text-white">Java Full Stack Developer</h3>
            <p class="text-sm text-slate-400 mb-2 italic">Univ. de La Punta (Argentina Programa 4.0) — 2023</p>
            <p class="text-xs text-slate-500 mb-4">Arquitectura: Java & SQL (Backend Profundo). Certificación reconocida por la CESSI.</p>
            
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 bg-white/5 px-2 py-1 rounded border border-white/10 text-[10px] text-slate-400 font-mono">
                    <Award size={12} class="text-primary"/>
                    <span>480 HORAS</span>
                </div>
                <a href={certJava.src} target="_blank" class="text-[11px] font-bold text-primary hover:underline inline-flex items-center gap-1 uppercase tracking-wider">
                    VER CERTIFICADO <ExternalLink size={12}/>
                </a>
            </div>
          </div>

          <div class="relative">
            <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-slate-700 border-4 border-base-100"></div>
            <h3 class="text-lg font-bold text-white">Programación Web Full Stack</h3>
            <p class="text-sm text-slate-400 mb-2 italic">Egg / Gobierno de Mendoza — 2021</p>
            <p class="text-xs text-slate-500 mb-4">Aprendizaje cooperativo basado en proyectos reales. Especialización en POO, Herencia y Persistencia (JDBC/JPA).</p>
            
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 bg-white/5 px-2 py-1 rounded border border-white/10 text-[10px] text-slate-400 font-mono">
                    <Award size={12} class="text-primary"/>
                    <span>500 HORAS</span>
                </div>
                <a href={certWeb.src} target="_blank" class="text-[11px] font-bold text-primary hover:underline inline-flex items-center gap-1 uppercase tracking-wider">
                    VER CERTIFICADO <ExternalLink size={12}/>
                </a>
            </div>
          </div>

          <div class="relative">
            <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-slate-700 border-4 border-base-100"></div>
            <h3 class="text-lg font-bold text-white">Python Scripting</h3>
            <p class="text-sm text-slate-400 mb-1 italic">UTN (Facultad Regional San Francisco) — 2023</p>
            <p class="text-xs text-slate-500">Lógica de programación y scripting avanzado.</p>

			<div class="flex items-center gap-4">
                <div class="flex items-center gap-2 bg-white/5 px-2 py-1 rounded border border-white/10 text-[10px] text-slate-400 font-mono">
                    <Award size={12} class="text-primary"/>
                    <span>48 HORAS</span>
                </div>
                <a href={certPython.src} target="_blank" class="text-[11px] font-bold text-primary hover:underline inline-flex items-center gap-1 uppercase tracking-wider">
                    VER CERTIFICADO <ExternalLink size={12}/>
                </a>
            </div>
          </div>

        </div>
      </section>
    </div>

    <div class="space-y-10">
      <div>
        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2 uppercase tracking-tighter">
          <span class="w-8 h-[2px] bg-primary"></span> Stack Técnico
        </h2>
        <div class="flex flex-wrap gap-2">
          {["Java 17", "Spring Boot", "PostgreSQL", "JPA / Hibernate", "Maven", "Git", "API REST", "Astro", "Tailwind"].map((skill) => (
            <span class="px-3 py-1.5 bg-white/[0.03] border border-white/10 rounded text-[11px] font-mono text-slate-300 hover:border-primary/50 transition-colors">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2 uppercase tracking-tighter">
          <span class="w-8 h-[2px] bg-secondary"></span> Soft Skills
        </h2>
        <ul class="space-y-3">
          {[
            "Liderazgo de Proyecto",
            "Resiliencia bajo presión",
            "Comunicación Directa",
            "Visión Arquitectónica",
            "Resolución de Problemas"
          ].map((skill) => (
            <li class="flex items-center gap-2 text-sm text-slate-400">
              <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
              {skill}
            </li>
          ))}
        </ul>
      </div>

      <div class="p-6 bg-primary/5 border border-primary/20 rounded-2xl">
          <p class="text-xs text-primary font-bold uppercase mb-2">Estado Actual</p>
          <p class="text-sm text-slate-300">Disponible para nuevos desafíos técnicos en el sector IT.</p>
      </div>
    </div>
  </div>
</MainLayout>